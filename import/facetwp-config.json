  "templates": [
    {
      "name": "led_treiber",
      "label": "LED-Treiber Produktliste",
      "query": "product",
      "template": "",
      "query_obj": {
        "post_type": "product",
        "post_status": "publish",
        "posts_per_page": 24,
        "tax_query": [],
        "meta_query": []
      },
      "modes": {
        "display": "visual",
        "query": "advanced"
      },
      "layout": {
        "type": "grid",
        "columns": 3,
        "grid_gap": 20
      },
      "pager": {
        "type": "numbers",
        "per_page": 24,
        "load_more_text": "Mehr laden",
        "loading_text": "Lade..."
      }
    }
  ],
  "settings": {
    "thousands_separator": "'",
    "decimal_separator": ".",
